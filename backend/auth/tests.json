{
  "tests": [
    {
      "name": "POST login — вход существующего пользователя",
      "method": "POST",
      "path": "/?action=login",
      "body": {"nickname": "Максим", "pin": "1111"},
      "expectedStatus": 200,
      "expectedBody": {"session_id": ""},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST login — неверный PIN",
      "method": "POST",
      "path": "/?action=login",
      "body": {"nickname": "Максим", "pin": "0000"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "POST register — новый пользователь",
      "method": "POST",
      "path": "/?action=register",
      "body": {"nickname": "ТестЮзер99", "pin": "5678", "car": "Lada Vesta"},
      "expectedStatus": 200,
      "expectedBody": {"session_id": ""},
      "bodyMatcher": "partial"
    }
  ]
}